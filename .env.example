# Server configuration
PORT=3001

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# JWT Configuration
JWT_SECRET=your_strong_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Domain Restriction
ALLOWED_DOMAIN=wareongo.com

# Admin allowlist (comma-separated emails). Users in this list can delete.
ADMIN_EMAILS=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL="your_database_connection_string"

# Twilio API credentials
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"

# Staging ingest webhook secret. Shared secret expected in the `x-webhook-secret`
# header on POST /api/staging/ingest. If unset/blank, the ingest endpoint is disabled
# (returns 503) — it fails closed. Generate a strong random value in production.
STAGING_INGEST_SECRET=

# Gupshup WhatsApp — review-outcome notifications to the submitter.
# OFF unless GUPSHUP_ENABLED is exactly "true". Leave disabled until the review
# flow goes live. When enabled, all of API_KEY/SOURCE/SRC_NAME/TEMPLATE_ID are
# required (otherwise sends are skipped with a warning). See src/services/gupshupService.js.
GUPSHUP_ENABLED=false
GUPSHUP_API_KEY=
GUPSHUP_SOURCE=          # registered WABA phone in E.164 form (no +)
GUPSHUP_SRC_NAME=        # Gupshup app name
GUPSHUP_TEMPLATE_ID=     # approved utility template id (4 params: name, id, status, comment)
# Optional: fixed comment sent on approvals (approvals carry no reviewer note).
GUPSHUP_APPROVE_COMMENT=
# Optional override; defaults to the self-serve /wa template endpoint.
GUPSHUP_ENDPOINT=

# Cloudflare R2 Credentials
R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"
R2_PUBLIC_URL="your_r2_public_url"